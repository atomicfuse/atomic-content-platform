---
/**
 * Category/archive page — lists articles for a topic with pagination.
 *
 * Generates pages at /category/{topic-slug}/ and /category/{topic-slug}/{page}.
 * Only generated when categories.enabled = true in config.
 */
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/SEOHead.astro';
import Header from '../../../../themes/modern/components/Header.astro';
import Footer from '../../../../themes/modern/components/Footer.astro';
import ArticleCard from '../../../../themes/modern/components/ArticleCard.astro';
import CategoryHeader from '../../../../themes/modern/components/CategoryHeader.astro';
import Pagination from '../../../../themes/modern/components/Pagination.astro';
import { getConfig } from '../../../config';
import { isVisibleArticle } from '../../../utils/article-status';

export const getStaticPaths = (async ({ paginate }) => {
  const config = await (await import('../../../config')).getConfig();

  if (!config.categories.enabled) {
    return [];
  }

  const topics = config.brief.topics ?? [];
  const articles = await getCollection('articles');
  const published = articles
    .filter((a) => isVisibleArticle(a.data.status))
    .sort(
      (a, b) =>
        new Date(b.data.publishDate).getTime() -
        new Date(a.data.publishDate).getTime(),
    );

  return topics.flatMap((topic) => {
    const topicSlug = topic.toLowerCase().replace(/\s+/g, '-');
    const topicArticles = published.filter((a) =>
      a.data.tags.some((t) => t.toLowerCase() === topic.toLowerCase()),
    );

    return paginate(topicArticles, {
      params: { topic: topicSlug },
      props: { topicName: topic, totalArticles: topicArticles.length },
      pageSize: config.categories.per_page,
    });
  });
}) satisfies GetStaticPaths;

const { page, topicName, totalArticles } = Astro.props;
const config = await getConfig();
const topicSlug = topicName.toLowerCase().replace(/\s+/g, '-');
const basePath = `/category/${topicSlug}`;
const canonicalUrl = `https://${config.domain}${basePath}`;
const pageTitle = page.currentPage > 1
  ? `${topicName} — Page ${page.currentPage} | ${config.site_name}`
  : `${topicName} | ${config.site_name}`;
---

<BaseLayout title={pageTitle} description={`${topicName} articles on ${config.site_name}`}>
  <Fragment slot="head">
    <SEOHead
      title={pageTitle}
      description={`Browse ${topicName} articles on ${config.site_name}`}
      canonicalUrl={canonicalUrl}
      siteName={config.site_name}
    />
  </Fragment>

  <Header config={config} currentPath={basePath} />

  <main class="category-page">
    <div class="container">
      <CategoryHeader name={topicName} articleCount={totalArticles} />

      {page.data.length > 0 ? (
        <div class="article-grid">
          {page.data.map((article) => (
            <ArticleCard
              title={article.data.title}
              slug={article.data.slug}
              featuredImage={article.data.featuredImage}
              description={article.data.description}
              author={article.data.author}
              publishDate={article.data.publishDate}
              tags={article.data.tags}
              type={article.data.type}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">No articles found in this category.</p>
      )}

      <Pagination
        currentPage={page.currentPage}
        totalPages={page.lastPage}
        basePath={basePath}
      />
    </div>
  </main>

  <Footer config={config} />
</BaseLayout>

<style>
  .category-page {
    min-height: 60vh;
  }

  .container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 1rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .empty-state {
    text-align: center;
    color: var(--color-muted, #9ca3af);
    padding: 4rem 0;
    font-size: 1.125rem;
  }
</style>
