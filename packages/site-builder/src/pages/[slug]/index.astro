---
/**
 * Article route — preview page or full article depending on config.
 *
 * When preview_page.enabled = true:
 *   Renders a preview with excerpt + "Continue Reading" CTA.
 *   The canonical URL is /{slug}/ (indexed by Google).
 *
 * When preview_page.enabled = false:
 *   Renders the full article directly (same as legacy [...slug].astro).
 */
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticlePreviewLayout from '../../layouts/ArticlePreviewLayout.astro';
import { getConfig } from '../../config';
import { getArticleExcerpt } from '../../utils/extract-excerpt';

const config = await getConfig();

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles
    .filter((a) => a.data.status === 'published')
    .map((article) => ({
      params: { slug: article.data.slug },
      props: { article },
    }));
}

const { article } = Astro.props;
const { Content } = await render(article);

// Determine if this is a preview page or full article
const previewEnabled = config.preview_page.enabled;

let excerptText = '';
let excerptIsHtml = false;

if (previewEnabled) {
  // Render the article to HTML to extract excerpt if needed
  // We use the frontmatter excerpt first, then fall back to auto-extraction
  const excerptResult = getArticleExcerpt(
    { excerpt: article.data.excerpt, description: article.data.description },
    null, // We don't render full HTML just for excerpt — rely on frontmatter
    config.preview_page.excerpt_paragraphs,
  );
  excerptText = excerptResult.text;
  excerptIsHtml = excerptResult.isHtml;
}
---

{previewEnabled ? (
  <ArticlePreviewLayout
    title={article.data.title}
    description={article.data.description ?? ''}
    author={article.data.author}
    publishDate={article.data.publishDate.toISOString().split('T')[0]!}
    featuredImage={article.data.featuredImage}
    slug={article.data.slug}
    excerpt={excerptText}
    excerptIsHtml={excerptIsHtml}
    tags={article.data.tags}
  />
) : (
  <ArticleLayout
    title={article.data.title}
    description={article.data.description ?? ''}
    author={article.data.author}
    publishDate={article.data.publishDate.toISOString().split('T')[0]!}
    featuredImage={article.data.featuredImage}
    slug={article.data.slug}
  >
    <Content />
  </ArticleLayout>
)}
