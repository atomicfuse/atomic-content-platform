---
/**
 * Full article page — only generated when preview pages are enabled.
 *
 * Renders the complete article content at /{slug}/full/.
 * SEO: noindex (canonical points back to preview at /{slug}/).
 */
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getConfig } from '../../config';
import { isVisibleArticle } from '../../utils/article-status';

const config = await getConfig();

export async function getStaticPaths() {
  const cfg = await (await import('../../config')).getConfig();

  // Only generate full article pages when preview is enabled
  if (!cfg.preview_page.enabled) {
    return [];
  }

  const articles = await getCollection('articles');
  return articles
    .filter((a) => isVisibleArticle(a.data.status))
    .map((article) => ({
      params: { slug: article.data.slug },
      props: { article },
    }));
}

const { article } = Astro.props;
const { Content } = await render(article);

// Canonical points back to the preview page
const canonicalUrl = `https://${config.domain}/${article.data.slug}`;
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description ?? ''}
  author={article.data.author}
  publishDate={article.data.publishDate.toISOString().split('T')[0]!}
  featuredImage={article.data.featuredImage}
  slug={article.data.slug}
  noindex={true}
  canonicalOverride={canonicalUrl}
>
  <Content />
</ArticleLayout>
