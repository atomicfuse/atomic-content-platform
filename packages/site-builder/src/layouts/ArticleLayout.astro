---
/**
 * Layout for individual article pages.
 *
 * Wraps BaseLayout and adds:
 *  - Modern theme Header and Footer
 *  - SEO head with article metadata
 *  - Hero featured image (full-width)
 *  - Article header (title, date, author)
 *  - Content area with prose styling
 *  - Ad slots positioned around content
 *  - RelatedPosts section below content
 *  - Sidebar with sticky ad on desktop
 */
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import AdSlot from '../components/AdSlot.astro';
import Header from '../../themes/modern/components/Header.astro';
import Footer from '../../themes/modern/components/Footer.astro';
import RelatedPosts from '../../themes/modern/components/RelatedPosts.astro';
import { getConfig } from '../config';

interface Props {
  title: string;
  description: string;
  author: string;
  publishDate: string;
  featuredImage?: string;
  slug: string;
}

const { title, description, author, publishDate, featuredImage, slug } = Astro.props;
const config = await getConfig();
const canonicalUrl = `https://${config.domain}/${slug}`;

// Separate ad placements by position type
const aboveContent = config.ads_config.ad_placements.filter(
  (p) => p.position === 'above-content',
);
const sidebar = config.ads_config.ad_placements.filter(
  (p) => p.position === 'sidebar',
);
const stickyBottom = config.ads_config.ad_placements.filter(
  (p) => p.position === 'sticky-bottom',
);

// Gather related posts (other published articles, excluding current)
const allArticles = await getCollection('articles');
const related = allArticles
  .filter((a) => a.data.status === 'published' && a.data.slug !== slug)
  .sort(
    (a, b) =>
      new Date(b.data.publishDate).getTime() -
      new Date(a.data.publishDate).getTime(),
  )
  .slice(0, 3)
  .map((a) => ({
    title: a.data.title,
    slug: a.data.slug,
    featuredImage: a.data.featuredImage,
    publishDate: a.data.publishDate,
  }));

const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | ${config.site_name}`} description={description}>
  <Fragment slot="head">
    <SEOHead
      title={`${title} | ${config.site_name}`}
      description={description}
      canonicalUrl={canonicalUrl}
      image={featuredImage}
      siteName={config.site_name}
      publishDate={publishDate}
    />
  </Fragment>

  <Header config={config} currentPath={`/${slug}`} />

  <main class="article-page">
    {/* Above-content ads */}
    {aboveContent.map((p) => <AdSlot placement={p} />)}

    {/* Hero image */}
    {featuredImage && (
      <div class="article-hero">
        <img src={featuredImage} alt={title} loading="eager" />
      </div>
    )}

    <div class="article-container">
      <article class="article-content">
        <header class="article-header">
          <h1>{title}</h1>
          <div class="article-meta">
            <span class="article-author">{author}</span>
            <time datetime={publishDate}>{formattedDate}</time>
          </div>
        </header>

        <div class="article-body prose">
          <slot />
        </div>

        {/* Related Posts */}
        <RelatedPosts articles={related} heading="You Might Also Like" />
      </article>

      {/* Sidebar ads (desktop only) */}
      {sidebar.length > 0 && (
        <aside class="article-sidebar">
          {sidebar.map((p) => <AdSlot placement={p} />)}
        </aside>
      )}
    </div>

    {/* Sticky bottom ads (mobile only) */}
    {stickyBottom.map((p) => <AdSlot placement={p} />)}
  </main>

  <Footer config={config} />
</BaseLayout>

<style>
  .article-page {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 1rem 2rem;
  }

  /* Hero */
  .article-hero {
    margin-bottom: 2rem;
    border-radius: var(--radius-lg, 12px);
    overflow: hidden;
  }

  .article-hero img {
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    display: block;
  }

  /* Two-column layout */
  .article-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 960px) {
    .article-container {
      grid-template-columns: 1fr 300px;
    }
  }

  /* Header */
  .article-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .article-header h1 {
    font-family: var(--fontHeading, sans-serif);
    font-size: var(--text-4xl, 2.25rem);
    line-height: 1.2;
    margin-bottom: 0.75rem;
    color: var(--color-text, #1a1a2e);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-muted, #6b7280);
    font-size: 0.9375rem;
  }

  .article-author {
    font-weight: 600;
    color: var(--color-text, #1a1a2e);
  }

  .article-meta time::before {
    content: '\00B7';
    margin-right: 0.75rem;
    color: var(--color-muted, #6b7280);
  }

  /* Body — prose styles from theme.css */
  .article-body {
    line-height: 1.8;
    font-size: 1.0625rem;
  }

  /* Sidebar */
  .article-sidebar {
    display: none;
  }

  @media (min-width: 960px) {
    .article-sidebar {
      display: block;
      position: sticky;
      top: 80px;
      align-self: start;
    }
  }
</style>
