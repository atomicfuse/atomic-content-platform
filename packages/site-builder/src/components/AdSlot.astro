---
/**
 * Renders an ad placement slot with appropriate sizing and device visibility.
 */
import type { AdPlacement } from '@atomic-platform/shared-types';

interface Props {
  placement: AdPlacement;
}

const { placement } = Astro.props;

// Determine visibility class based on device targeting
const deviceClass =
  placement.device === 'desktop'
    ? 'hidden md:block'
    : placement.device === 'mobile'
      ? 'block md:hidden'
      : '';

// Serialise sizes for data attributes
const desktopSizes = (placement.sizes.desktop ?? [])
  .map((s) => s.join('x'))
  .join(',');
const mobileSizes = (placement.sizes.mobile ?? [])
  .map((s) => s.join('x'))
  .join(',');

// Use the first available size entry for CLS-friendly min dimensions
const firstDesktop = placement.sizes.desktop?.[0];
const firstMobile = placement.sizes.mobile?.[0];
const firstSize = firstDesktop ?? firstMobile;
const minWidth = firstSize ? `${firstSize[0]}px` : 'auto';
const minHeight = firstSize ? `${firstSize[1]}px` : 'auto';
---

<div
  class:list={['ad-slot', deviceClass]}
  data-ad-id={placement.id}
  data-sizes-desktop={desktopSizes}
  data-sizes-mobile={mobileSizes}
  style={`min-width:${minWidth};min-height:${minHeight};`}
>
  <span class="ad-label">Advertisement</span>
</div>

<style>
  .ad-slot {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 1rem auto;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    position: relative;
  }
  .ad-label {
    position: absolute;
    top: 2px;
    left: 4px;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #9ca3af;
  }
</style>
