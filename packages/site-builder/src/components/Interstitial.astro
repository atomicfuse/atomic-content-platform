---
/**
 * Full-screen interstitial ad overlay.
 * Only renders markup when `enabled` is true.
 * Uses a small inline script for show/hide behaviour.
 */

interface Props {
  enabled: boolean;
}

const { enabled } = Astro.props;
---

{enabled && (
  <div id="interstitial-overlay" class="interstitial" aria-hidden="true" style="display:none;">
    <div class="interstitial-backdrop"></div>
    <div class="interstitial-content">
      <div class="interstitial-header">
        <span id="interstitial-countdown" class="interstitial-timer"></span>
        <button id="interstitial-close" class="interstitial-close-btn" aria-label="Close advertisement">
          &times;
        </button>
      </div>
      <div id="interstitial-ad-container" class="interstitial-ad">
        {/* Ad network SDK fills this container */}
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var overlay = document.getElementById('interstitial-overlay');
      var closeBtn = document.getElementById('interstitial-close');
      var countdown = document.getElementById('interstitial-countdown');
      if (!overlay || !closeBtn || !countdown) return;

      function show() {
        overlay.style.display = 'flex';
        overlay.setAttribute('aria-hidden', 'false');
        var seconds = 5;
        countdown.textContent = 'Close in ' + seconds + 's';
        closeBtn.disabled = true;
        var timer = setInterval(function () {
          seconds--;
          if (seconds <= 0) {
            clearInterval(timer);
            countdown.textContent = '';
            closeBtn.disabled = false;
          } else {
            countdown.textContent = 'Close in ' + seconds + 's';
          }
        }, 1000);
      }

      function hide() {
        overlay.style.display = 'none';
        overlay.setAttribute('aria-hidden', 'true');
      }

      closeBtn.addEventListener('click', hide);

      // Expose global for ad network SDK to trigger
      window.__interstitial = { show: show, hide: hide };
    })();
  </script>
)}

<style>
  .interstitial {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .interstitial-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
  }
  .interstitial-content {
    position: relative;
    z-index: 1;
    background: #fff;
    border-radius: 8px;
    max-width: 90vw;
    max-height: 90vh;
    overflow: auto;
    padding: 1rem;
  }
  .interstitial-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .interstitial-timer {
    font-size: 0.75rem;
    color: #6b7280;
  }
  .interstitial-close-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem;
    color: #374151;
  }
  .interstitial-close-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }
  .interstitial-ad {
    min-width: 300px;
    min-height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
