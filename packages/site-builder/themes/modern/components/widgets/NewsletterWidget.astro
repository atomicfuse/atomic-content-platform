---
/**
 * Sidebar newsletter signup widget — compact email subscription form.
 */

interface Props {
  siteName: string;
}

const { siteName } = Astro.props;
---

<div class="widget widget-newsletter">
  <h3 class="widget-title">Stay Updated</h3>
  <p class="widget-desc">Get the latest from {siteName}</p>
  <form data-newsletter-form data-source="sidebar" class="newsletter-form">
    <input
      type="email"
      name="email"
      placeholder="Your email"
      required
      class="newsletter-input"
      aria-label="Email address"
    />
    <button type="submit" class="newsletter-btn">Subscribe</button>
    <input name="_hp" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px" />
  </form>
</div>

<style>
  .widget-newsletter {
    padding: 1.25rem;
    background: var(--color-surface, #f8f9fa);
    border-radius: var(--radius-md, 8px);
  }

  .widget-title {
    font-family: var(--fontHeading, sans-serif);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: var(--color-text, #1a1a2e);
  }

  .widget-desc {
    font-size: 0.8125rem;
    color: var(--color-muted, #6b7280);
    margin-bottom: 0.75rem;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .newsletter-input {
    width: 100%;
    padding: 0.625rem 0.875rem;
    font-size: 0.9375rem;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-md, 8px);
    background: var(--color-background, #fff);
    color: var(--color-text, #1a1a2e);
    min-height: 44px;
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-primary, #0066ff);
    box-shadow: 0 0 0 2px rgba(0, 102, 255, 0.15);
  }

  .newsletter-btn {
    width: 100%;
    padding: 0.625rem;
    min-height: 44px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #fff;
    background: var(--color-primary, #0066ff);
    border: none;
    border-radius: var(--radius-md, 8px);
    cursor: pointer;
    transition: background var(--transition-fast, 150ms ease);
  }

  .newsletter-btn:hover {
    background: var(--color-accent, #0052cc);
  }

  .newsletter-success {
    color: #10b981;
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }

  .newsletter-error {
    color: #ef4444;
    font-size: 0.8125rem;
    margin-top: 0.5rem;
  }
</style>

<script src="../../scripts/newsletter-subscribe.ts"></script>
