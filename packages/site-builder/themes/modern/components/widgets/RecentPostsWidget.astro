---
/**
 * Sidebar recent posts widget — compact list of recent article titles.
 */

interface ArticleData {
  title: string;
  slug: string;
  publishDate: Date | string;
  featuredImage?: string;
}

interface Props {
  articles: ArticleData[];
  count?: number;
}

const { articles, count = 5 } = Astro.props;
const recentArticles = articles.slice(0, count);
---

<div class="widget widget-recent">
  <h3 class="widget-title">Recent Posts</h3>
  <ul class="recent-list">
    {recentArticles.map((article) => {
      const date = new Date(article.publishDate).toLocaleDateString('en-US', {
        month: 'short',
        day: 'numeric',
      });
      return (
        <li class="recent-item">
          <a href={`/${article.slug}`} class="recent-link">
            {article.featuredImage && (
              <img
                src={article.featuredImage}
                alt=""
                class="recent-thumb"
                loading="lazy"
              />
            )}
            <div class="recent-body">
              <span class="recent-title">{article.title}</span>
              <time datetime={new Date(article.publishDate).toISOString()} class="recent-date">
                {date}
              </time>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</div>

<style>
  .widget-recent {
    padding: 1.25rem;
    background: var(--color-surface, #f8f9fa);
    border-radius: var(--radius-md, 8px);
  }

  .widget-title {
    font-family: var(--fontHeading, sans-serif);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--color-text, #1a1a2e);
  }

  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .recent-item {
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .recent-item:last-child {
    border-bottom: none;
  }

  .recent-link {
    display: flex;
    gap: 0.75rem;
    padding: 0.625rem 0;
    text-decoration: none;
    color: inherit;
    transition: opacity var(--transition-fast, 150ms ease);
    align-items: center;
  }

  .recent-link:hover {
    opacity: 0.8;
  }

  .recent-thumb {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: var(--radius-sm, 4px);
    flex-shrink: 0;
  }

  .recent-body {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .recent-title {
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-text, #1a1a2e);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .recent-date {
    font-size: 0.75rem;
    color: var(--color-muted, #6b7280);
  }
</style>
