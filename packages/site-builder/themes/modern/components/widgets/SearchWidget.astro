---
/**
 * Sidebar search widget — navigates to /search with query parameter.
 */
---

<div class="widget widget-search">
  <h3 class="widget-title">Search</h3>
  <form action="/search" method="get" class="search-form">
    <input
      type="search"
      name="q"
      placeholder="Search articles..."
      class="search-input"
      aria-label="Search articles"
    />
    <button type="submit" class="search-btn" aria-label="Submit search">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
    </button>
  </form>
</div>

<style>
  .widget-search {
    padding: 1.25rem;
    background: var(--color-surface, #f8f9fa);
    border-radius: var(--radius-md, 8px);
  }

  .widget-title {
    font-family: var(--fontHeading, sans-serif);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--color-text, #1a1a2e);
  }

  .search-form {
    display: flex;
    gap: 0;
  }

  .search-input {
    flex: 1;
    padding: 0.625rem 0.875rem;
    font-size: 0.9375rem;
    border: 1px solid var(--color-border, #e5e7eb);
    border-right: none;
    border-radius: var(--radius-md, 8px) 0 0 var(--radius-md, 8px);
    background: var(--color-background, #fff);
    color: var(--color-text, #1a1a2e);
    min-height: 44px;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-primary, #0066ff);
    box-shadow: 0 0 0 2px rgba(0, 102, 255, 0.15);
  }

  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    min-height: 44px;
    border: 1px solid var(--color-primary, #0066ff);
    background: var(--color-primary, #0066ff);
    color: #fff;
    border-radius: 0 var(--radius-md, 8px) var(--radius-md, 8px) 0;
    cursor: pointer;
    transition: background var(--transition-fast, 150ms ease);
  }

  .search-btn:hover {
    background: var(--color-accent, #0052cc);
  }
</style>
