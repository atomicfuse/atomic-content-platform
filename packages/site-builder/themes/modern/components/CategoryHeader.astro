---
/**
 * Modern theme — category/archive page header.
 *
 * Displays the topic name as a large heading with an article count badge.
 */

interface Props {
  name: string;
  articleCount: number;
}

const { name, articleCount } = Astro.props;
---

<header class="category-header">
  <h1 class="category-title">{name}</h1>
  <span class="category-count">
    {articleCount} {articleCount === 1 ? 'article' : 'articles'}
  </span>
</header>

<style>
  .category-header {
    padding: 2rem 0 1.5rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
    margin-bottom: 2rem;
  }

  .category-title {
    font-family: var(--fontHeading, sans-serif);
    font-size: var(--text-3xl, 1.875rem);
    font-weight: 700;
    color: var(--color-text, #1a1a2e);
    margin-bottom: 0.5rem;
  }

  .category-count {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-muted, #6b7280);
    background: var(--color-surface, #f8f9fa);
    border-radius: var(--radius-sm, 4px);
  }

  @media (max-width: 639px) {
    .category-title {
      font-size: var(--text-2xl, 1.5rem);
    }
  }
</style>
