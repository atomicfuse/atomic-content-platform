---
/**
 * Modern theme — contact form.
 *
 * Simple name / email / message form with a submit button.
 * Displays the support email for reference.
 */

interface Props {
  supportEmail: string;
}

const { supportEmail } = Astro.props;
---

<section class="contact-section">
  <div class="contact-inner">
    <h2 class="contact-heading">Get in Touch</h2>
    <p class="contact-desc">
      Have a question or feedback? Send us a message and we will get back to you.
    </p>
    {supportEmail && (
      <p class="contact-email">
        Or email us directly at{' '}
        <a href={`mailto:${supportEmail}`}>{supportEmail}</a>
      </p>
    )}

    <form class="contact-form" action="#" method="post">
      <div class="form-group">
        <label for="contact-name" class="form-label">Name</label>
        <input
          type="text"
          id="contact-name"
          name="name"
          required
          class="form-input"
          placeholder="Your name"
        />
      </div>

      <div class="form-group">
        <label for="contact-email" class="form-label">Email</label>
        <input
          type="email"
          id="contact-email"
          name="email"
          required
          class="form-input"
          placeholder="you@example.com"
        />
      </div>

      <div class="form-group">
        <label for="contact-message" class="form-label">Message</label>
        <textarea
          id="contact-message"
          name="message"
          rows="5"
          required
          class="form-textarea"
          placeholder="Your message..."
        ></textarea>
      </div>

      <button type="submit" class="form-submit">Send Message</button>
    </form>
  </div>
</section>

<style>
  .contact-section {
    padding: 3rem 0;
  }

  .contact-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .contact-heading {
    font-family: var(--fontHeading, sans-serif);
    font-size: var(--text-3xl, 1.875rem);
    font-weight: 700;
    color: var(--color-text, #1a1a2e);
    margin-bottom: 0.5rem;
  }

  .contact-desc {
    font-size: 1rem;
    color: var(--color-muted, #6b7280);
    margin-bottom: 0.5rem;
  }

  .contact-email {
    font-size: 0.875rem;
    color: var(--color-muted, #6b7280);
    margin-bottom: 2rem;
  }

  .contact-email a {
    color: var(--color-primary, #0066ff);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text, #1a1a2e);
  }

  .form-input,
  .form-textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-md, 8px);
    font-size: 0.9375rem;
    font-family: inherit;
    color: var(--color-text, #1a1a2e);
    background: var(--color-background, #fff);
    outline: none;
    transition: border-color var(--transition-fast, 150ms ease),
                box-shadow var(--transition-fast, 150ms ease);
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--color-primary, #0066ff);
    box-shadow: 0 0 0 3px rgba(0, 102, 255, 0.1);
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: #9ca3af;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    align-self: flex-start;
    padding: 0.75rem 2rem;
    background: var(--color-primary, #0066ff);
    color: #fff;
    border: none;
    border-radius: var(--radius-md, 8px);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background var(--transition-fast, 150ms ease);
  }

  .form-submit:hover {
    background: var(--color-accent, #00ccff);
  }
</style>
