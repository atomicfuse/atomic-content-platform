---
/**
 * Modern theme — newsletter signup section.
 *
 * Standalone call-to-action block with email input and subscribe button.
 */

interface Props {
  siteName: string;
}

const { siteName } = Astro.props;
---

<section class="newsletter-section">
  <div class="newsletter-inner">
    <div class="newsletter-text">
      <h2 class="newsletter-heading">Stay Updated</h2>
      <p class="newsletter-desc">
        Get the latest from {siteName} delivered straight to your inbox. No spam, unsubscribe anytime.
      </p>
    </div>
    <form class="newsletter-form" data-newsletter-form data-source="homepage">
      <input
        type="email"
        name="email"
        placeholder="Enter your email"
        required
        class="newsletter-input"
      />
      <button type="submit" class="newsletter-btn">Subscribe</button>
      <input name="_hp" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px" />
    </form>
  </div>
</section>

<style>
  .newsletter-section {
    padding: 3rem 0;
  }

  .newsletter-inner {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 2.5rem 2rem;
    background: var(--color-surface, #f8f9fa);
    border-radius: var(--radius-xl, 16px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .newsletter-inner {
      flex-direction: row;
      text-align: left;
      padding: 2.5rem 3rem;
    }
  }

  .newsletter-text {
    flex: 1;
  }

  .newsletter-heading {
    font-family: var(--fontHeading, sans-serif);
    font-size: var(--text-2xl, 1.5rem);
    font-weight: 700;
    color: var(--color-text, #1a1a2e);
    margin-bottom: 0.5rem;
  }

  .newsletter-desc {
    font-size: 0.9375rem;
    color: var(--color-muted, #6b7280);
    line-height: 1.5;
    max-width: 420px;
  }

  .newsletter-form {
    display: flex;
    gap: 0;
    width: 100%;
    max-width: 400px;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border, #e5e7eb);
    border-right: none;
    border-radius: 8px 0 0 8px;
    font-size: 0.9375rem;
    color: var(--color-text, #1a1a2e);
    background: var(--color-background, #fff);
    outline: none;
    transition: border-color var(--transition-fast, 150ms ease);
  }

  .newsletter-input::placeholder {
    color: var(--color-muted, #6b7280);
  }

  .newsletter-input:focus {
    border-color: var(--color-primary, #0066ff);
  }

  .newsletter-btn {
    padding: 0.75rem 1.5rem;
    background: var(--color-accent, #00ccff);
    color: #fff;
    border: none;
    border-radius: 0 8px 8px 0;
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    transition: background var(--transition-fast, 150ms ease);
    white-space: nowrap;
  }

  .newsletter-btn:hover {
    background: var(--color-primary, #0066ff);
  }

  .newsletter-success {
    color: #10b981;
    font-size: 0.9375rem;
    margin-top: 0.5rem;
  }

  .newsletter-error {
    color: #ef4444;
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }
</style>

<script src="../scripts/newsletter-subscribe.ts"></script>
