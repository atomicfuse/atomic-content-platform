---
/**
 * "Continue Reading" call-to-action button for preview pages.
 * Full-width on mobile, centered on desktop, with prominent theme styling.
 */

interface Props {
  href: string;
  text?: string;
}

const { href, text = 'Continue Reading' } = Astro.props;
---

<div class="cta-wrapper">
  <a href={href} class="cta-button">
    {text}
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </a>
</div>

<style>
  .cta-wrapper {
    display: flex;
    justify-content: center;
    padding: 2rem 0;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    max-width: 400px;
    min-height: 52px;
    padding: 0.875rem 2rem;
    font-family: var(--fontHeading, sans-serif);
    font-size: 1.125rem;
    font-weight: 600;
    color: #fff;
    background-color: var(--color-primary, #0066ff);
    border-radius: var(--radius-md, 8px);
    text-decoration: none;
    transition:
      background-color var(--transition-base, 250ms ease),
      transform var(--transition-fast, 150ms ease),
      box-shadow var(--transition-base, 250ms ease);
    cursor: pointer;
  }

  .cta-button:hover {
    background-color: var(--color-accent, #0052cc);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md, 0 4px 12px rgba(0, 0, 0, 0.15));
  }

  .cta-button:active {
    transform: translateY(0);
  }

  .cta-button svg {
    flex-shrink: 0;
  }

  @media (max-width: 639px) {
    .cta-wrapper {
      padding: 1.5rem 0;
    }

    .cta-button {
      max-width: none;
    }
  }
</style>
