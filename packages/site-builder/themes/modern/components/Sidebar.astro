---
/**
 * Modern theme — configurable sidebar.
 *
 * Renders widgets based on the sidebar configuration.
 * Collapses below main content on mobile.
 */
import type { ResolvedConfig } from '@atomic-platform/shared-types';
import SearchWidget from './widgets/SearchWidget.astro';
import RecentPostsWidget from './widgets/RecentPostsWidget.astro';
import CategoriesWidget from './widgets/CategoriesWidget.astro';
import NewsletterWidget from './widgets/NewsletterWidget.astro';

interface ArticleData {
  title: string;
  slug: string;
  publishDate: Date | string;
  featuredImage?: string;
}

interface Props {
  config: ResolvedConfig;
  articles: ArticleData[];
}

const { config, articles } = Astro.props;
const widgets = config.sidebar.widgets.filter((w) => w.enabled !== false);
const sidebarHeight = config.ad_placeholder_heights.sidebar;
---

<aside class="sidebar">
  {widgets.map((widget) => {
    switch (widget.type) {
      case 'search':
        return <SearchWidget />;
      case 'recent_posts':
        return (
          <RecentPostsWidget
            articles={articles}
            count={(widget.options?.count as number) ?? 5}
          />
        );
      case 'categories':
        return (
          <CategoriesWidget
            topics={config.brief.topics ?? []}
            categoriesEnabled={config.categories.enabled}
          />
        );
      case 'newsletter':
        return <NewsletterWidget siteName={config.site_name} />;
      case 'ad':
        return (
          <div
            data-slot="sidebar"
            class="sidebar-ad-anchor"
            style={`min-height:${sidebarHeight}px;`}
          />
        );
      default:
        return null;
    }
  })}
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 960px) {
    .sidebar {
      position: sticky;
      top: 80px;
      align-self: start;
    }
  }
</style>
