---
/**
 * Modern theme — related posts grid.
 *
 * Displays a 3-column grid (responsive) of smaller article cards
 * with thumbnail, title, and date.
 */

interface RelatedArticle {
  title: string;
  slug: string;
  featuredImage?: string;
  publishDate: Date | string;
}

interface Props {
  articles: RelatedArticle[];
  heading?: string;
}

const { articles, heading = 'Related Posts' } = Astro.props;
---

{articles.length > 0 && (
  <section class="related-section">
    <h2 class="related-heading">{heading}</h2>
    <div class="related-grid">
      {articles.map((article) => {
        const date = new Date(article.publishDate).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        return (
          <a href={`/${article.slug}`} class="related-card">
            <div class="related-image-wrap">
              {article.featuredImage ? (
                <img src={article.featuredImage} alt={article.title} loading="lazy" class="related-image" />
              ) : (
                <div class="related-image-placeholder"></div>
              )}
            </div>
            <div class="related-body">
              <h3 class="related-title">{article.title}</h3>
              <time datetime={new Date(article.publishDate).toISOString()} class="related-date">
                {date}
              </time>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}

<style>
  .related-section {
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--color-border, #e5e7eb);
    margin-top: 3rem;
  }

  .related-heading {
    font-family: var(--fontHeading, sans-serif);
    font-size: var(--text-2xl, 1.5rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-text, #1a1a2e);
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .related-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-md, 8px);
    overflow: hidden;
    border: 1px solid var(--color-border, #e5e7eb);
    transition: box-shadow var(--transition-base, 250ms ease),
                transform var(--transition-base, 250ms ease);
  }

  .related-card:hover {
    box-shadow: var(--shadow-md, 0 4px 12px rgba(0, 0, 0, 0.08));
    transform: translateY(-1px);
  }

  .related-image-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface, #f8f9fa);
  }

  .related-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base, 250ms ease);
  }

  .related-card:hover .related-image {
    transform: scale(1.03);
  }

  .related-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-surface, #f8f9fa), var(--color-border, #e5e7eb));
  }

  .related-body {
    padding: 0.875rem 1rem;
  }

  .related-title {
    font-family: var(--fontHeading, sans-serif);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-text, #1a1a2e);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.375rem;
  }

  .related-date {
    font-size: 0.8125rem;
    color: var(--color-muted, #6b7280);
  }
</style>
