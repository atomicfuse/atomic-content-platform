---
/**
 * Modern theme — sticky top navigation bar.
 *
 * Renders the site logo, horizontal topic navigation, and a search icon.
 * On mobile a hamburger button toggles a slide-in drawer.
 */
import type { ResolvedConfig } from '@atomic-platform/shared-types';

interface Props {
  config: ResolvedConfig;
  currentPath: string;
}

const { config, currentPath } = Astro.props;

// Show first 5 topics as nav items
const navTopics = (config.brief.topics ?? []).slice(0, 5);
const categoriesEnabled = config.categories.enabled;
const searchEnabled = config.search.enabled;

/** Build the URL for a topic link. */
function topicHref(topic: string): string {
  const slug = topic.toLowerCase().replace(/\s+/g, '-');
  return categoriesEnabled ? `/category/${slug}` : `/#${slug}`;
}
---

<header class="site-nav" id="site-nav">
  <div class="nav-inner">
    {/* Logo */}
    <a href="/" class="nav-logo" aria-label={config.site_name}>
      {config.theme.logo ? (
        <img src={config.theme.logo} alt={config.site_name} class="logo-img" />
      ) : (
        <span class="logo-text">{config.site_name}</span>
      )}
    </a>

    {/* Desktop nav links */}
    <nav class="nav-links" aria-label="Main navigation">
      {navTopics.map((topic) => (
        <a href={topicHref(topic)} class="nav-link">
          {topic}
        </a>
      ))}
    </nav>

    {/* Right actions */}
    <div class="nav-actions">
      {/* Search icon — links to /search when enabled, otherwise decorative */}
      {searchEnabled ? (
        <a href="/search" class="nav-icon-btn" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
        </a>
      ) : (
        <button class="nav-icon-btn" aria-label="Search" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
        </button>
      )}

      {/* Mobile hamburger */}
      <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" type="button">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  {/* Mobile drawer */}
  <div class="mobile-drawer" id="mobile-drawer">
    <nav class="drawer-links">
      <a href="/" class="drawer-link">Home</a>
      {navTopics.map((topic) => (
        <a href={topicHref(topic)} class="drawer-link">
          {topic}
        </a>
      ))}
    </nav>
  </div>
</header>

{/* Spacer to offset sticky header */}
<div class="nav-spacer"></div>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const drawer = document.getElementById('mobile-drawer');

  hamburger?.addEventListener('click', () => {
    const isOpen = drawer?.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    hamburger.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
  });
</script>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-background, #fff);
    border-bottom: 1px solid var(--color-border, #e5e7eb);
    backdrop-filter: blur(8px);
    background-color: rgba(255, 255, 255, 0.95);
  }

  .nav-inner {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1rem;
    height: 64px;
  }

  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    height: 56px;
    width: auto;
  }

  .logo-text {
    font-family: var(--fontHeading, sans-serif);
    font-size: 1.375rem;
    font-weight: 800;
    color: var(--color-primary, #0066ff);
    letter-spacing: -0.02em;
  }

  /* Desktop nav */
  .nav-links {
    display: none;
    gap: 0.25rem;
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-link {
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text, #1a1a2e);
    border-radius: 6px;
    transition: background var(--transition-fast, 150ms ease),
                color var(--transition-fast, 150ms ease);
    text-decoration: none;
  }

  .nav-link:hover {
    background: var(--color-surface, #f8f9fa);
    color: var(--color-primary, #0066ff);
  }

  /* Right actions */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    background: none;
    border-radius: 50%;
    cursor: pointer;
    color: var(--color-text, #1a1a2e);
    transition: background var(--transition-fast, 150ms ease);
  }

  .nav-icon-btn:hover {
    background: var(--color-surface, #f8f9fa);
  }

  /* Hamburger */
  .nav-hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    border: none;
    background: none;
    cursor: pointer;
    padding: 8px;
  }

  @media (min-width: 768px) {
    .nav-hamburger {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text, #1a1a2e);
    border-radius: 2px;
    transition: transform var(--transition-base, 250ms ease),
                opacity var(--transition-base, 250ms ease);
  }

  /* Mobile drawer */
  .mobile-drawer {
    position: fixed;
    top: 64px;
    right: 0;
    bottom: 0;
    width: 280px;
    background: var(--color-background, #fff);
    border-left: 1px solid var(--color-border, #e5e7eb);
    transform: translateX(100%);
    transition: transform var(--transition-base, 250ms ease);
    z-index: 99;
    overflow-y: auto;
    padding: 1rem 0;
  }

  .mobile-drawer.is-open {
    transform: translateX(0);
  }

  .drawer-links {
    display: flex;
    flex-direction: column;
  }

  .drawer-link {
    display: block;
    padding: 0.875rem 1.5rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text, #1a1a2e);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
    transition: background var(--transition-fast, 150ms ease);
  }

  .drawer-link:hover {
    background: var(--color-surface, #f8f9fa);
    color: var(--color-primary, #0066ff);
  }

  /* Spacer */
  .nav-spacer {
    height: 64px;
  }
</style>
