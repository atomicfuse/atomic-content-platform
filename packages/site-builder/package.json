{
  "name": "@atomic-platform/site-builder",
  "version": "0.1.0",
  "private": true,
  "description": "Astro static site generator — themes, components, build scripts, config resolver",
  "scripts": {
    "prebuild": "tsx scripts/build-site.ts",
    "predev": "tsx scripts/build-site.ts",
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "astro check && tsc --noEmit",
    "clean": "rm -rf dist .astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.3.0",
    "@atomic-platform/shared-types": "workspace:*",
    "astro": "^5.7.0",
    "pagefind": "^1.3.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^25.5.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
