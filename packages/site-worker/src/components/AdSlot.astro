---
/**
 * Server Island — emits an empty ad container per the resolved
 * monetization config in KV. The bundled `mock-ad-fill.js` script
 * (loaded in BaseLayout) scans for `[data-ad-id]` elements at runtime
 * and fills them with mock creatives — preserving the visual parity
 * we had with the legacy site-builder.
 *
 * Real ad-network SDKs replace `mock-ad-fill.js` later (see
 * `docs/future-decisions.md`).
 */
import { getConfig } from '../lib/config';

export interface Props {
  /** Position name as defined in the resolved `ads_config.ad_placements[].position`.
   *  Examples from groups/taboola.yaml:
   *  `above-content` | `below-content` | `sidebar` | `sticky-bottom` |
   *  `homepage-top` | `homepage-mid` | `category-top` | `after-paragraph-N`. */
  position: string;
  /** Page type filter — taboola/group placements use top-level slot
   *  conventions, but BaseLayout/articles can render different sets per
   *  page type. Currently informational only (`data-ad-page-type`). */
  pageType: 'homepage' | 'article' | 'category';
}

interface Placement {
  id?: string;
  position?: string;
  device?: 'all' | 'desktop' | 'mobile';
  sizes?: { desktop?: number[][]; mobile?: number[][] };
  pages?: string[];
}

const { position, pageType } = Astro.props;
const config = getConfig(Astro);
const heights = config.ad_placeholder_heights as unknown as Record<string, number> | undefined;
const placements = ((config.ads_config?.ad_placements as Placement[] | undefined) ?? []).filter(
  (p) => p.position === position && (!p.pages || p.pages.includes(pageType)),
);

if (placements.length === 0) {
  // No matching placement → render nothing.
}

const reserved = heights?.[position] ?? heights?.[position.replace(/-\d+$/, '')] ?? 0;
const styleParts = [
  reserved ? `min-height:${reserved}px` : '',
  position === 'sticky-bottom'
    ? 'position:fixed;bottom:0;left:0;right:0;z-index:100;background:rgba(255,255,255,0.95);text-align:center'
    : '',
].filter(Boolean);
---

{placements.map((p) => (
  <div
    data-ad-id={p.id ?? `${position}-${pageType}`}
    data-ad-position={position}
    data-ad-page-type={pageType}
    data-ad-device={p.device ?? 'all'}
    data-ad-sizes={JSON.stringify(p.sizes ?? {})}
    class={`atl-ad-slot atl-ad-${position}`}
    style={styleParts.join(';')}
  ></div>
))}

{position === 'sticky-bottom' && placements.length > 0 && (
  <button
    class="atl-ad-close"
    aria-label="Close advertisement"
    data-atl-close="sticky-bottom"
    type="button"
  >×</button>
)}

<script>
  // Sticky-bottom dismiss — mirrors legacy public/ad-loader.js behaviour.
  // Session-scoped so a closed ad stays closed for the tab's lifetime.
  if (sessionStorage.getItem('_atl_sticky_dismissed') === '1') {
    document.querySelectorAll('.atl-ad-sticky-bottom').forEach((el) => {
      (el as HTMLElement).style.display = 'none';
    });
  }
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement | null;
    if (!t) return;
    if (t.matches('[data-atl-close="sticky-bottom"]')) {
      sessionStorage.setItem('_atl_sticky_dismissed', '1');
      document.querySelectorAll('.atl-ad-sticky-bottom').forEach((el) => {
        (el as HTMLElement).style.display = 'none';
      });
    }
  });
</script>

<style is:global>
  .atl-ad-slot {
    display: block;
    margin: 0.75rem auto;
  }
  .atl-ad-close {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 32px;
    height: 32px;
    border: 1px solid #333;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    cursor: pointer;
    font-size: 16px;
    z-index: 101;
  }
</style>
