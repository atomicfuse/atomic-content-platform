---
/**
 * Server Island — emits an empty ad container per the resolved
 * monetization config in KV. The bundled `mock-ad-fill.js` script
 * (loaded in BaseLayout) scans for `[data-ad-id]` elements at runtime
 * and fills them with mock creatives — preserving the visual parity
 * we had with the legacy site-builder.
 *
 * Real ad-network SDKs replace `mock-ad-fill.js` later (see
 * `docs/future-decisions.md`).
 *
 * Sticky-bottom rendering: the slot div + close button are wrapped in
 * a position:fixed container so the close button anchors to the
 * sticky bar (not the viewport corner) and survives mock-ad-fill.js
 * replacing the inner ad div content.
 */
import { getConfig } from '../lib/config';

export interface Props {
  position: string;
  pageType: 'homepage' | 'article' | 'category';
}

interface Placement {
  id?: string;
  position?: string;
  device?: 'all' | 'desktop' | 'mobile';
  sizes?: { desktop?: number[][]; mobile?: number[][] };
  pages?: string[];
}

const { position, pageType } = Astro.props;
const config = getConfig(Astro);
const heights = config.ad_placeholder_heights as unknown as Record<string, number> | undefined;
const placements = ((config.ads_config?.ad_placements as Placement[] | undefined) ?? []).filter(
  (p) => p.position === position && (!p.pages || p.pages.includes(pageType)),
);

const reserved = heights?.[position] ?? heights?.[position.replace(/-\d+$/, '')] ?? 0;
const slotInlineStyle = reserved ? `min-height:${reserved}px` : '';
const isSticky = position === 'sticky-bottom';
---

{!isSticky && placements.map((p) => (
  <div
    data-ad-id={p.id ?? `${position}-${pageType}`}
    data-ad-position={position}
    data-ad-page-type={pageType}
    data-ad-device={p.device ?? 'all'}
    data-ad-sizes={JSON.stringify(p.sizes ?? {})}
    class={`atl-ad-slot atl-ad-${position}`}
    style={slotInlineStyle}
  ></div>
))}

{isSticky && placements.length > 0 && (
  <div class="atl-ad-sticky-wrapper" data-atl-sticky-wrapper>
    {placements.map((p) => (
      <div
        data-ad-id={p.id ?? `${position}-${pageType}`}
        data-ad-position={position}
        data-ad-page-type={pageType}
        data-ad-device={p.device ?? 'all'}
        data-ad-sizes={JSON.stringify(p.sizes ?? {})}
        class={`atl-ad-slot atl-ad-${position}`}
        style={slotInlineStyle}
      ></div>
    ))}
    <button
      class="atl-ad-close"
      aria-label="Close advertisement"
      data-atl-close="sticky-bottom"
      type="button"
    >×</button>
  </div>
)}

<script>
  // Sticky-bottom dismiss — mirrors legacy public/ad-loader.js.
  function hideSticky(): void {
    document.querySelectorAll('[data-atl-sticky-wrapper]').forEach((el) => {
      (el as HTMLElement).style.display = 'none';
    });
  }
  if (sessionStorage.getItem('_atl_sticky_dismissed') === '1') hideSticky();
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement | null;
    if (t?.matches('[data-atl-close="sticky-bottom"]')) {
      sessionStorage.setItem('_atl_sticky_dismissed', '1');
      hideSticky();
    }
  });
</script>

<style is:global>
  .atl-ad-slot {
    display: block;
    margin: 0.75rem auto;
  }
  .atl-ad-sticky-wrapper {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    text-align: center;
    /* Acts as the positioning context for .atl-ad-close. */
  }
  .atl-ad-sticky-wrapper .atl-ad-slot {
    margin: 0 auto;
  }
  .atl-ad-close {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 32px;
    height: 32px;
    border: 1px solid #333;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    z-index: 101;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .atl-ad-close:focus-visible {
    outline: 2px solid #0066cc;
    outline-offset: 2px;
  }
</style>
