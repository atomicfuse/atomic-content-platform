---
export const prerender = false;

import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { isVisibleArticle } from '../../utils/article-status';

type ArticleEntry = CollectionEntry<'articles'>;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/', 302);
}

const all = await getCollection('articles');
const entry = all.find((a: ArticleEntry) => a.data.slug === slug && isVisibleArticle(a.data.status));

if (!entry) {
  return new Response('Not found', { status: 404 });
}

const { Content } = await render(entry);
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description ?? entry.data.title}
  author={entry.data.author}
  publishDate={entry.data.publishDate.toISOString()}
  featuredImage={entry.data.featuredImage}
  slug={entry.data.slug}
>
  <Content />
</ArticleLayout>
