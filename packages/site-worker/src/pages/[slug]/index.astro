---
export const prerender = false;

import { env } from 'cloudflare:workers';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { getConfig, getSiteId } from '../../lib/config';
import { articleKey, sharedPageKey, type ArticleRecord, type SharedPage } from '../../lib/kv-schema';
import { isVisibleArticle } from '../../utils/article-status';
import { injectInlineAds } from '../../lib/inline-ads';

const SHARED_PAGES = new Set(['about', 'contact', 'privacy', 'terms', 'dmca']);

const { slug } = Astro.params;

if (!slug) {
  return new Response('Not found', { status: 404 });
}

const siteId = getSiteId(Astro);

// Shared pages live at top-level slugs (`/about`, `/privacy`, ...) and
// take precedence over the article namespace. If the slug matches a
// shared name we look it up first; only then fall through to articles.
const shared: SharedPage | null = SHARED_PAGES.has(slug)
  ? ((await env.CONFIG_KV.get<SharedPage>(sharedPageKey(siteId, slug), 'json')) ?? null)
  : null;

const article: ArticleRecord | null = shared
  ? null
  : ((await env.CONFIG_KV.get<ArticleRecord>(articleKey(siteId, slug), 'json')) ?? null);

if (!shared && (!article || !isVisibleArticle(article.frontmatter.status))) {
  return new Response('Not found', { status: 404 });
}

// Inject after-paragraph-N ad slots into the article body server-side.
// The legacy site-builder did this client-side via ad-loader.js; doing it
// in the request path keeps the slot present in the initial HTML so it
// caches consistently with the article shell.
const articleBodyWithInlineAds = article
  ? injectInlineAds(
      article.body,
      (getConfig(Astro).ads_config?.ad_placements as Array<{ id?: string; position?: string }> | undefined) ?? [],
    )
  : '';
---

{shared && (
  <PageLayout title={shared.title} slug={slug}>
    <Fragment set:html={shared.html} />
  </PageLayout>
)}

{article && (
  <ArticleLayout
    title={article.frontmatter.title}
    description={article.frontmatter.description ?? article.frontmatter.title}
    author={article.frontmatter.author}
    publishDate={new Date(article.frontmatter.publishDate).toISOString()}
    featuredImage={article.frontmatter.featuredImage}
    slug={article.frontmatter.slug}
  >
    <Fragment set:html={articleBodyWithInlineAds} />
  </ArticleLayout>
)}
